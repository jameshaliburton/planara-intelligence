# ── Email (Resend) ────────────────────────────────────────────
# Required. Get an API key at https://resend.com.
# The sending domain must be verified in Resend (SPF + DKIM DNS records)
# before mail will deliver.
RESEND_API_KEY=re_xxxxxxxxxxxx

# Optional. Override the From address. Default is "Planara <hello@planara.com>".
# Recommended for production: send from a transactional subdomain
# (e.g. notifications@send.planara.com) so transactional reputation is
# isolated from the primary domain. Requires DNS records on the subdomain.
EMAIL_FROM=hello@planara.com
EMAIL_FROM_NAME=Planara

# Optional. Where pilot applications get delivered. Defaults to
# pilots@planara.com — point at a real mailbox or forwarder.
PILOTS_INBOX=pilots@planara.com

# ── Cloudflare Turnstile (anti-bot, optional) ─────────────────
# When both vars are set, all forms render the Turnstile widget and the
# server validates the resulting token before accepting submissions.
# Provision a site at https://dash.cloudflare.com/?to=/:account/turnstile
# Without these vars, forms submit without the challenge (dev mode).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
